{
  "name": "chat-app-microfrontend",
  "version": "0.0.0",
  "private": true,
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || >=24.0.0"
  },
  "scripts": {
    "start": "nx run-many --target=serve --projects=mfe_chat,mfe_contacts,shell --parallel --verbose",
    "start:shell": "nx serve shell --verbose",
    "start:chat": "nx serve mfe_chat",
    "start:contacts": "nx serve mfe_contacts",
    "build": "nx run-many --target=build --all --parallel",
    "build:shell": "nx build shell",
    "build:chat": "nx build mfe_chat",
    "build:contacts": "nx build mfe_contacts",
    "lint": "nx run-many --target=lint --all --parallel",
    "test": "nx run-many --target=test --all --parallel",
    "typecheck": "nx run-many --target=typecheck --all --parallel",
    "graph": "nx graph",
    "affected:build": "nx affected --target=build",
    "affected:lint": "nx affected --target=lint",
    "affected:test": "nx affected --target=test"
  },
